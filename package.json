{
  "name": "ledgerflow-pro",
  "version": "1.0.0",
  "description": "Excel Add-in for Accountants — encrypted OneDrive storage",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"webpack serve --config webpack.config.js --mode development\"",
    "server": "node server/server.js",
    "build": "webpack --config webpack.config.js --mode production",
    "sideload": "office-addin-debugging start manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.28.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-manifest": "^2.1.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
