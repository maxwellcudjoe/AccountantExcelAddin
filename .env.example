# LedgerFlow Pro — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

# ── Database (MS SQL / Azure SQL) ─────────────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=your_server.database.windows.net
DB_NAME=ledgerflow

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7264
FRONTEND_URL=https://localhost:3000

# ── Azure Entra ID (for OneDrive / Graph API MSAL) ───────────────────────────
# Register app at https://portal.azure.com → Entra ID → App registrations
# Add delegated permission: Microsoft Graph → Files.ReadWrite
# Add redirect URIs: https://localhost:3000 and your production Azure URL
AZURE_CLIENT_ID=your_entra_app_client_id
